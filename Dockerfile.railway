# Single-container deploy for Render: API + worker run in same process (worker as daemon thread)
# Local multi-container dev: use docker-compose.yml

FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --upgrade pip && pip install --no-cache-dir -r requirements.txt

COPY app/ app/
COPY worker/ worker/

EXPOSE 8004

# Use shell form so ${PORT} is expanded at runtime (Render injects PORT)
CMD python -m uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8004}
